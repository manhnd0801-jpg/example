      "id": "pbc-auth",
      "displayName": "Authentication & Authorization",
      "version": "1.0.0",
      "remoteEntry": "${CDN_BASE_URL}/pbc-auth/remoteEntry.js",
      "exposedModule": "./LoginSlot",
      "mountPath": "/login",
      "scope": "pbc_auth",
      "lazy": false,
      "order": 0,
      "label": "Đăng nhập & Phân quyền",
      "icon": "UserOutlined",
      "requiredEvents": [],
      "emittedEvents": [
        "auth.user.loggedIn",
        "auth.user.loggedOut",
        "auth.token.refreshed",
        "auth.user.loginFailed"
      ],
      "healthCheck": "${API_BASE_URL}/health",
      "permissions": [],
      "environments": {
        "local": {
          "remoteEntry": "http://localhost:3000/remotes/pbc-auth/assets/remoteEntry.js"
        },
        "staging": {
          "remoteEntry": "https://cdn-staging.example.vn/pbc-auth/remoteEntry.js"
        },
