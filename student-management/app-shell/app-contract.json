{
  "appId": "student-management",
  "version": "1.0.0",
  "name": "Student Management Portal",
  "description": "Hệ thống quản lý sinh viên",
  "category": "Education",
  "domain": "student-management",
  "includedPBCs": [
    { "pbcId": "pbc-auth", "version": "1.0.0" },
    { "pbcId": "pbc-student-management", "version": "1.0.0" },
    { "pbcId": "pbc-class-management", "version": "1.0.0" },
    { "pbcId": "pbc-course-management", "version": "1.0.0" },
    { "pbcId": "pbc-subject-management", "version": "1.0.0" },
    { "pbcId": "pbc-notification", "version": "1.0.0" }
  ],
  "eventBus": {
    "type": "kafka",
    "version": "3.x",
    "topicPrefix": "pbc"
  },
  "appShell": {
    "framework": "react",
    "moduleFederation": true,
    "uiStrategy": "module-federation",
    "federationPlugin": "@originjs/vite-plugin-federation",
    "basePath": "/",
    "defaultRoute": "/students"
  },
  "theme": {
    "primaryColor": "#1677ff",
    "radius": "8px",
    "fontFamily": "Inter, sans-serif"
  },
  "security": {
    "authPBC": "pbc-auth",
    "publicRoutes": ["/login", "/health"],
    "defaultPolicy": "authenticated"
  },
  "i18n": {
    "defaultLocale": "vi",
    "supportedLocales": ["vi", "en"]
  }
}
