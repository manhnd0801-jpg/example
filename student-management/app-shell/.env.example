# App Shell Environment Variables
# Copy sang .env.local để chạy local

# Kafka Gateway WebSocket URL (browser kết nối vào đây — R-03a, R-12)
VITE_KAFKA_GATEWAY_URL=ws://localhost:4000

# CDN và API base URL
VITE_CDN_BASE_URL=http://localhost:3010
VITE_API_BASE_URL=http://localhost:8090

# Environment: local | staging | production
VITE_ENV=local

# Tenant ID
VITE_TENANT_ID=dev-tenant
