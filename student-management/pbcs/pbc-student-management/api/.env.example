# AI-GENERATED
# Environment variables for Student Management PBC API

# Server Configuration
NODE_ENV=development
PORT=3002

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/student_management
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=student_management
DB_SCHEMA=tenant_default

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Kafka Configuration
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=pbc-student-management
KAFKA_CONSUMER_GROUP=cg.student-mgmt

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.xlsx,.xls

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000